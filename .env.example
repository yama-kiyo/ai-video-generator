# API Keys - 各サービスでAPIキーを取得し、ここに設定してください
# 詳細は README.md を参照

# Google Gemini API (Veo 3.1 動画生成)
# 取得先: https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Runway API (Gen4.5 動画生成) - オプション
# 取得先: https://app.runwayml.com/settings/api-keys
RUNWAY_API_KEY=your-runway-api-key-here

# ElevenLabs API (音声合成)
# 取得先: https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
